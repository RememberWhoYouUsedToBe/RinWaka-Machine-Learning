{
    // 你原有的配置（保留）
    "python-envs.pythonProjects": [
        {
            "path": ".",
            "envManager": "ms-python.python:venv",
            "packageManager": "ms-python.python:pip"
        }
    ],
    // 新增：白名单模式，只启用以下扩展
    "extensions.enabled": [
        "ms-python.python",           // Python 主扩展
        "ms-python.vscode-pylance",   // Python 语言服务器
        "ms-python.debugpy",          // Python 调试器
        "ms-toolsai.jupyter",         // Jupyter Notebook 支持
        "ms-python.pylint",           // 代码检查（可替换为你常用的 linter）
        "ms-python.isort",            // import 排序
        // 如果需要，可以再添加一些通用扩展，比如 GitLens、Remote-SSH 等
        "eamodio.gitlens"
    ],
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        ".",
        "-p",
        "*test*.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true
}